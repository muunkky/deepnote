project:
  id: 00000000-0000-0000-0000-0000000000b1
  name: bash-image-integration
  notebooks:
    - blocks:
        - id: 00000000-0000-0000-0000-0000000000b3
          blockGroup: "0"
          sortingKey: "000000"
          contentHash: sha256:e042c437d6f4f8ecd1ec8c606857b4bac8bf7f0e67ce31e3ad713c4c9f943683
          type: markdown
          content: >-
            # Bash image output


            Emits an `image/png` via the bash_kernel `display` helper.
          metadata: {}
        - id: 00000000-0000-0000-0000-0000000000b4
          blockGroup: "1"
          sortingKey: "000001"
          contentHash: sha256:a153826f2060ff4b529a098973585b60170ef9e86b59b3e48d6b7999eb7cddf0
          outputs:
            - output_type: stream
              name: stdout
              text: >
                bash: syntax error near unexpected token `('
            - output_type: stream
              name: stdout
              text: >
                bash: syntax error near unexpected token `'{}''
            - output_type: stream
              name: stdout
              text: >
                bash: else:: command not found
            - output_type: stream
              name: stdout
              text: >
                bash: _deepnote_current_table_attrs: command not found
            - output_type: display_data
              data:
                image/png: iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==
              metadata: {}
          type: code
          content: >
            # Decode a minimal valid 1x1 PNG and emit it as an image/png display_data

            # via the bash_kernel `display` helper (`cat <png> | display`). This drives a

            # real binary MIME bundle back through the JSON-only WebSocket transport and

            # the IOPub decode path — the headline launch criterion (R7).

            tmp="${TMPDIR:-/tmp}/deepnote-bash-fixture-$$.png"

            printf '%s'
            'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==' | base64
            -d > "$tmp"

            cat "$tmp" | display

            rm -f "$tmp"
          metadata: {}
      id: 00000000-0000-0000-0000-0000000000b2
      name: BashImage
version: 1.0.0
