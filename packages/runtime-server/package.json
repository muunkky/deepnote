{
  "name": "@deepnote/runtime-server",
  "version": "0.0.0",
  "description": "The deepnote serve backend: a Node host fronting one ExecutionEngine, exposing the notebook project over HTTP and streaming run events over WebSocket",
  "keywords": [
    "deepnote",
    "notebook",
    "server",
    "execution",
    "websocket"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/deepnote/deepnote.git",
    "directory": "packages/runtime-server"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/api-types.js",
      "require": "./dist/api-types.cjs",
      "types": "./dist/api-types.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "watch": "tsdown --watch",
    "check:types-subpath": "tsc --noEmit -p tsconfig.capstone.json"
  },
  "dependencies": {
    "@deepnote/blocks": "workspace:*",
    "@deepnote/reactivity": "workspace:*",
    "@deepnote/runtime-core": "workspace:*",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  },
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.17.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
